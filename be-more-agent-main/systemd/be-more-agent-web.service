[Unit]
Description=Be More Pi Robot Web UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/Ai-Robot/be-more-agent-main
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/Ai-Robot/be-more-agent-main/venv/bin/python -m uvicorn web_app:app --host 0.0.0.0 --port 8090
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
