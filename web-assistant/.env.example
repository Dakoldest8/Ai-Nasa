# Web Assistant Configuration
# Copy to .env and customize for your environment

# Flask Configuration
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database - MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=nasa_ai_system
DB_TABLE=users

# Flask SQLAlchemy (for personal.db - optional)
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/nasa_ai_system
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Federated Learning
FEDERATED_LEARNING=true
ENCRYPTION_KEY=your-encryption-key-change-in-production

# API Configuration  
WEB_ASSISTANT_PORT=5000
API_HOST=0.0.0.0

# Pi Robot Communication
PI_ROBOT_HOST=localhost
PI_ROBOT_PORT=5001
PI_WEB_URL=http://127.0.0.1:8090

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/web-assistant.log

# Security
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
MAX_CONTENT_LENGTH=16777216
