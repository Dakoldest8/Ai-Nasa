# Astronaut AI Ecosystem - Root Configuration
# Copy to .env and fill in your values

# Deployment Environment
ENVIRONMENT=development
DEBUG=True

# Shared Services
SHARED_API_HOST=localhost
SHARED_API_PORT=5000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306  
DB_USER=root
DB_PASSWORD=password
DB_NAME=nasa_ai_system

# Web Assistant (Flask)
WEB_ASSISTANT_PORT=5000
WEB_ASSISTANT_URL=http://localhost:5000

# Pi Robot Agent (on-screen/Tkinter GUI)
PI_ROBOT_PORT=5001

# Pi Robot Web Interface (FastAPI, for browser access)
PI_ROBOT_WEB_PORT=8090
PI_ROBOT_WEB_URL=http://127.0.0.1:8090

# PHP Frontend (via XAMPP/Apache)
XAMPP_PORT=8080
PHP_URL=http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ecosystem.log

