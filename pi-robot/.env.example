# Pi Robot Configuration
# Copy to .env and customize for your environment

# Robot Configuration
ROBOT_NAME=AI-Bot
ROBOT_ID=robot-001

# API Configuration
API_HOST=0.0.0.0
PI_ROBOT_PORT=5001

# Web Assistant Communication
WEB_ASSISTANT_HOST=localhost
WEB_ASSISTANT_PORT=5000

# Speech & Audio Engines
TTS_ENGINE=pyttsx3
STT_ENGINE=google
AUDIO_DEVICE_INDEX=0

# Local LLM Configuration
LOCAL_LLM=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=neural-chat

# Knowledge Base
KNOWLEDGE_BASE_PATH=data/knowledge_base

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pi-robot.log

# Hardware (Raspberry Pi)
RPI_GPIO_PIN_LED=17
RPI_GPIO_PIN_BUTTON=27
DISPLAY_CONNECTED=true

# Performance
MAX_INFERENCE_TIME=5000
CACHE_ENABLED=true
